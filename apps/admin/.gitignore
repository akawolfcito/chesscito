# Append-only audit log of admin tx executions. Contains tx hashes,
# calldata, gas usage, and the wallet that signed — sensitive operational
# metadata that doesn't belong in the public repo. The directory itself
# stays in git via the .gitkeep marker.
audit-log/*
!audit-log/.gitkeep

# Encrypted admin keystore lives here. Even though the contents are
# AES-256-GCM encrypted, keeping the file out of the repo entirely
# eliminates any risk of an accidental commit + brute-force attempt.
.private/

node_modules
dist
.tsbuildinfo
