{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "description": "MiniPay MiniApp for playful cognitive enrichment through pre-chess challenges",
  "author": "Wolfcito (@akawolfcito)",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "lint": "next lint",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:visual": "playwright test e2e/visual-snapshot.spec.ts",
    "test:e2e:redesign": "playwright test e2e/redesign-validation.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "type-check": "rm -rf .next && next build >/dev/null && tsc --noEmit",
    "art:optimize": "bash scripts/optimize-art-assets.sh",
    "encrypt-key": "npx tsx scripts/encrypt-key.ts"
  },
  "comments": {
    "versions": "Team convention — exact pins (no ^ or ~) for every dependency to harden against malicious version-range hijacks. See feedback_exact_version_pins memory."
  },
  "dependencies": {
    "@lottiefiles/dotlottie-react": "0.18.7",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-slot": "1.2.4",
    "@rainbow-me/rainbowkit": "2.2.10",
    "@supabase/supabase-js": "2.100.1",
    "@tanstack/react-query": "5.90.21",
    "@upstash/ratelimit": "2.0.8",
    "@upstash/redis": "1.37.0",
    "@vercel/analytics": "2.0.1",
    "chess.js": "1.4.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "ethers": "6.16.0",
    "js-chess-engine": "2.4.6",
    "lottie-react": "2.4.1",
    "lucide-react": "0.292.0",
    "next": "14.2.35",
    "openai": "6.32.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sharp": "0.34.5",
    "tailwind-merge": "2.6.1",
    "viem": "2.46.3",
    "wagmi": "2.19.5",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "20.19.35",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/ui": "4.1.4",
    "autoprefixer": "10.4.27",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.35",
    "jsdom": "29.0.2",
    "postcss": "8.5.8",
    "tailwindcss": "3.4.19",
    "tailwindcss-animate": "1.0.7",
    "typescript": "5.9.3",
    "vitest": "4.1.4"
  }
