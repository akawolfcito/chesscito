{
  "name": "hardhat",
  "version": "1.0.0",
  "description": "Smart contracts for chesscito",
  "main": "index.js",
  "scripts": {
    "build": "hardhat compile && node scripts/generate-event-abis.mjs",
    "compile": "hardhat compile",
    "generate:event-abis": "node scripts/generate-event-abis.mjs",
    "test": "hardhat test",
    "deploy": "hardhat run scripts/deploy-proxies.ts",
    "deploy:alfajores": "hardhat run scripts/deploy-proxies.ts --network alfajores",
    "deploy:celo-sepolia": "hardhat run scripts/deploy-proxies.ts --network celo-sepolia",
    "deploy:celo": "hardhat run scripts/deploy-proxies.ts --network celo",
    "verify": "hardhat run scripts/verify.ts",
    "verify:alfajores": "hardhat run scripts/verify.ts --network alfajores",
    "verify:celo-sepolia": "hardhat run scripts/verify.ts --network celo-sepolia",
    "verify:celo": "hardhat run scripts/verify.ts --network celo",
    "clean": "hardhat clean",
    "typechain": "hardhat typechain",
    "deploy:shop": "hardhat run scripts/deploy-shop.ts",
    "deploy:shop:celo-sepolia": "hardhat run scripts/deploy-shop.ts --network celo-sepolia",
    "deploy:shop:celo": "hardhat run scripts/deploy-shop.ts --network celo",
    "configure:shop": "hardhat run scripts/configure-shop.ts",
    "configure:shop:celo-sepolia": "hardhat run scripts/configure-shop.ts --network celo-sepolia",
    "configure:shop:celo": "hardhat run scripts/configure-shop.ts --network celo",
    "verify:all": "hardhat run scripts/verify.ts",
    "verify:all:alfajores": "hardhat run scripts/verify.ts --network alfajores",
    "verify:all:celo-sepolia": "hardhat run scripts/verify.ts --network celo-sepolia",
    "verify:all:celo": "hardhat run scripts/verify.ts --network celo",
    "verify:proxies": "hardhat run scripts/verify-implementations.ts",
    "verify:proxies:alfajores": "hardhat run scripts/verify-implementations.ts --network alfajores",
    "verify:proxies:celo-sepolia": "hardhat run scripts/verify-implementations.ts --network celo-sepolia",
    "verify:proxies:celo": "hardhat run scripts/verify-implementations.ts --network celo"
  },
  "keywords": [
    "hardhat",
    "ethereum",
    "celo",
    "smart-contracts",
    "solidity"
  ],
  "author": "",
  "license": "Apache-2.0",
  "comments": {
    "versions": "Team convention — exact pins (no ^ or ~) for every dependency to harden against malicious version-range hijacks. See feedback_exact_version_pins memory."
